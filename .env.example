# Copy to .env and adjust. .env is gitignored; never commit real secrets.
# In production these come from your orchestrator's secret store, not a file.

# --- relay tuning ---
CONCORD_BATCH_SIZE=200
CONCORD_MAX_ATTEMPTS=8
CONCORD_POLL_INTERVAL_MS=50
CONCORD_BACKOFF_BASE_S=0.5
CONCORD_BACKOFF_CAP_S=30.0
CONCORD_LOG_LEVEL=INFO

# --- infra (local docker-compose defaults) ---
CONCORD_DATABASE_URL=postgresql://concord:concord@localhost:5432/concord
CONCORD_KAFKA_BOOTSTRAP=localhost:9092
CONCORD_REDIS_URL=redis://localhost:6379/0
CONCORD_MINIO_ENDPOINT=localhost:9000
CONCORD_MINIO_BUCKET=concord-deadletter

# --- secrets (example values; override everywhere real) ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
